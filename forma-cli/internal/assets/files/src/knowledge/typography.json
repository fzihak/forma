{
  "version": "2.0",
  "schema": "ultra-advanced-fluid",
  "scale": [
    {
      "token": "text-xs",
      "size": "clamp(0.75rem, 0.72rem + 0.16vw, 0.875rem)",
      "line_height": "1.4",
      "use_cases": ["Footers", "Meta tags", "Badges"]
    },
    {
      "token": "text-sm",
      "size": "clamp(0.875rem, 0.84rem + 0.18vw, 1rem)",
      "line_height": "1.5",
      "use_cases": ["Navigation", "Secondary text"]
    },
    {
      "token": "text-base",
      "size": "clamp(1rem, 0.95rem + 0.23vw, 1.125rem)",
      "line_height": "1.6",
      "use_cases": ["Primary body text", "Paragraphs"]
    },
    {
      "token": "text-lg",
      "size": "clamp(1.125rem, 1.07rem + 0.28vw, 1.25rem)",
      "line_height": "1.5",
      "use_cases": ["Subheadings", "Lead paragraphs"]
    },
    {
      "token": "text-xl",
      "size": "clamp(1.25rem, 1.18rem + 0.36vw, 1.5rem)",
      "line_height": "1.4",
      "use_cases": ["H4", "Card Titles"]
    },
    {
      "token": "text-2xl",
      "size": "clamp(1.5rem, 1.39rem + 0.54vw, 1.875rem)",
      "line_height": "1.3",
      "use_cases": ["H3", "Section Headers"]
    },
    {
      "token": "text-3xl",
      "size": "clamp(1.875rem, 1.7rem + 0.85vw, 2.25rem)",
      "line_height": "1.2",
      "use_cases": ["H2", "Major Titles"]
    },
    {
      "token": "text-4xl",
      "size": "clamp(2.25rem, 1.98rem + 1.36vw, 3rem)",
      "line_height": "1.1",
      "use_cases": ["H1", "Hero Primary (Mobile)"]
    },
    {
      "token": "text-5xl",
      "size": "clamp(3rem, 2.54rem + 2.27vw, 4.5rem)",
      "line_height": "1",
      "use_cases": ["Hero Primary (Desktop)", "Display Text"]
    }
  ]
}