{
  "name": "E-Commerce",
  "description": "Conversion-optimized shopping platforms balancing product discovery with frictionless checkout.",
  "psychology_triggers": [
    "Scarcity",
    "Social Proof",
    "Anchoring",
    "Zeigarnik Effect"
  ],
  "industry_constraints": [
    "Performance/Load time critical (<2s)",
    "Mobile-first indexability"
  ],
